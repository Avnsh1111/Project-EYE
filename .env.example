APP_NAME="Avinash EYE"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database — PostgreSQL with pgvector
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=avinash_eye
DB_USERNAME=avinash
DB_PASSWORD=secret

# Queue
QUEUE_CONNECTION=database

# Cache
CACHE_STORE=database

# Session
SESSION_DRIVER=database

# Laravel Reverb WebSocket
BROADCAST_DRIVER=reverb
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=avinash-eye
REVERB_APP_KEY=local-reverb-key
REVERB_APP_SECRET=local-reverb-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8081
REVERB_SCHEME=http

# Python AI service
AI_API_URL=http://python-ai:8000
AI_DEFAULT_TIMEOUT=120
AI_TIMEOUT=120
AI_CIRCUIT_BREAKER_THRESHOLD=10
AI_CIRCUIT_BREAKER_RECOVERY=30
AI_RETRY_MAX_ATTEMPTS=3

# Node.js image processor
NODE_PROCESSOR_URL=http://node-processor:3000
NODE_PROCESSOR_TIMEOUT=600

# Ollama LLM (optional) — consumed by python-ai service, not Laravel
OLLAMA_URL=http://ollama:11434
OLLAMA_ENABLED=true
OLLAMA_MODEL=llava:13b-v1.6

# Elasticsearch
SCOUT_DRIVER=elasticsearch
ELASTICSEARCH_HOST=http://elasticsearch:9200

# Default admin user (created on first run)
DEFAULT_USER_EMAIL=admin@avinash-eye.local
DEFAULT_USER_PASSWORD=Admin@123
DEFAULT_USER_NAME=Administrator
